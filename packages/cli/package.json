{
  "name": "@drift-ci/cli",
  "version": "1.1.0",
  "description": "Behaviour regression testing for LLM applications",
  "license": "MIT",
  "homepage": "https://github.com/Drift-CI/drift-ci#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drift-CI/drift-ci.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Drift-CI/drift-ci/issues"
  },
  "type": "module",
  "bin": {
    "drift-ci": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/add-shebang.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@drift-ci/core": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "ink": "^7.0.5",
    "js-yaml": "^4.2.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.8",
    "ink-testing-library": "^4.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
