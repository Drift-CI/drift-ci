{
  "name": "@drift-ci/core",
  "version": "1.1.0",
  "description": "drift-ci core engine: types, providers, evaluators, storage, runner",
  "license": "MIT",
  "homepage": "https://github.com/Drift-CI/drift-ci#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drift-CI/drift-ci.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Drift-CI/drift-ci/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./evaluators": {
      "import": "./dist/evaluators/index.js",
      "types": "./dist/evaluators/index.d.ts"
    },
    "./engine/*": {
      "import": "./dist/engine/*.js",
      "types": "./dist/engine/*.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.js",
      "types": "./dist/storage/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.22.4",
    "@anthropic-ai/sdk": "^0.60.0",
    "@google/genai": "^1.50.1",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.2.0",
    "openai": "^6.42.0",
    "p-limit": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^1.6.1",
    "fast-xml-parser": "^4.5.6",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0",
    "postgres": "^3.4.5"
  }
}
