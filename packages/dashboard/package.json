{
  "name": "@drift-ci/dashboard",
  "version": "1.1.0",
  "private": true,
  "description": "drift-ci self-hostable dashboard — Next.js 15 + Postgres",
  "scripts": {
    "build": "next build",
    "start": "next start",
    "dev": "next dev",
    "lint": "next lint --no-cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node scripts/migrate.mjs",
    "db:generate": "drizzle-kit generate",
    "retention:sweep": "node scripts/retention.mjs",
    "clean": "rimraf .next dist coverage"
  },
  "dependencies": {
    "@drift-ci/core": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "next": "^15.0.3",
    "postgres": "^3.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.15",
    "rimraf": "^6.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
